#!/bin/bash
# Pre-push hook: run gitleaks before any push to a remote
# Blocks push if secrets are detected in commits being pushed

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

GITLEAKS=""
if command -v gitleaks &>/dev/null; then
  GITLEAKS="gitleaks"
elif [ -x /tmp/gitleaks ]; then
  GITLEAKS="/tmp/gitleaks"
fi

if [ -z "$GITLEAKS" ]; then
  echo -e "${RED}WARNING: gitleaks not found — secret scan skipped${NC}"
  echo -e "${RED}Install: brew install gitleaks${NC}"
  exit 0
fi

CONFIG=""
if [ -f ".gitleaks.toml" ]; then
  CONFIG="--config .gitleaks.toml"
fi

echo -e "Running gitleaks pre-push scan..."
$GITLEAKS detect $CONFIG -v 2>&1
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo ""
  echo -e "${RED}BLOCKED: Secrets detected — push aborted${NC}"
  echo -e "${RED}Fix the leaks above, then try again${NC}"
  exit 1
fi

echo -e "${GREEN}No leaks found — push allowed${NC}"
exit 0
